# =============================================================================
# HERBAMARKETER — Environment Variables
# =============================================================================
# Rinomina questo file in .env e compila tutti i valori
# MAI committare il file .env su Git — è già in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# ANTHROPIC
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID_OMAR=XXXXXXXXXX
# Opzionale: se vuoi che anche Emiliano riceva le notifiche
TELEGRAM_CHAT_ID_EMILIANO=

# -----------------------------------------------------------------------------
# MAUTIC  (https://broadcast.herbago.info)
# -----------------------------------------------------------------------------
MAUTIC_URL=https://broadcast.herbago.info
MAUTIC_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MAUTIC_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# BREVO  (per herbashop.it)
# -----------------------------------------------------------------------------
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BREVO_SENDER_NAME=HerbaShop
BREVO_SENDER_EMAIL=info@herbashop.it

# -----------------------------------------------------------------------------
# EMAIL INGESTOR  (Gmail IMAP per topic da email inoltrate)
# -----------------------------------------------------------------------------
INGESTOR_EMAIL=tuoindirizzo@gmail.com
INGESTOR_PASSWORD=xxxx xxxx xxxx xxxx    # App Password Gmail (non password account)
INGESTOR_IMAP_HOST=imap.gmail.com
INGESTOR_IMAP_PORT=993

# -----------------------------------------------------------------------------
# WORDPRESS — Application Passwords (utente n8n-api su ogni sito)
# Formato password: "xxxx xxxx xxxx xxxx xxxx xxxx" (con spazi, come generata da WP)
# -----------------------------------------------------------------------------
WP_HERBAGO_IT_USER=herba-api
WP_HERBAGO_IT_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

WP_HERBAGO_FR_USER=herba-api
WP_HERBAGO_FR_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

WP_HERBAGO_DE_USER=herba-api
WP_HERBAGO_DE_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

WP_HERBAGO_NET_USER=herba-api
WP_HERBAGO_NET_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

WP_HERBAGO_CO_UK_USER=herba-api
WP_HERBAGO_CO_UK_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

WP_HLIFEUS_USER=herba-api
WP_HLIFEUS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

WP_HERBASHOP_IT_USER=herba-api
WP_HERBASHOP_IT_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# -----------------------------------------------------------------------------
# DATAFORSEO
# -----------------------------------------------------------------------------
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# IMAGE GENERATION — scegli uno dei due
# -----------------------------------------------------------------------------
# Opzione A: Ideogram (consigliato, qualità superiore per lifestyle/natura)
IDEOGRAM_API_KEY=

# Opzione B: OpenAI DALL-E 3
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Sviluppo Mac (SQLite — nessuna configurazione necessaria)
DATABASE_URL=sqlite:///./herbamarketer.db

# Produzione Coolify (PostgreSQL — decommenta e compila quando deployed)
# DATABASE_URL=postgresql://herbamarketer:PASSWORD@localhost:5432/herbamarketer

# -----------------------------------------------------------------------------
# SCHEDULER — intervalli in giorni
# -----------------------------------------------------------------------------
EMAIL_JOB_INTERVAL_DAYS=15
ARTICLE_JOB_INTERVAL_DAYS=15
KEYWORD_RESEARCH_INTERVAL_DAYS=30

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
APP_ENV=development
# APP_ENV=production
LOG_LEVEL=INFO
DASHBOARD_PORT=8000
# Secret per sessioni dashboard (genera con: python -c "import secrets; print(secrets.token_hex(32))")
DASHBOARD_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
